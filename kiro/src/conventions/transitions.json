{
  "description": "State machine transitions for AI-DLC stage execution. Each edge has at most one condition. Intermediate states make fork decisions explicit and self-explaining.",
  "conditions": {
    "has-contributors": "stage.contributors exists and has length > 0",
    "no-contributors": "stage.contributors is absent or empty",
    "has-reviewer": "stage.reviewer is set",
    "no-reviewer": "stage.reviewer is absent",
    "all-contributors-done": "all entries in stage.contributions have contributed: true",
    "review-not-maxed": "stage.reviewIterations < maxReviewIterations",
    "review-maxed-or-ready": "stage.reviewIterations >= maxReviewIterations OR reviewer verdict is ready",
    "decision-approve": "--decision argument provided and is an approval",
    "decision-reject": "--decision argument provided and is a rejection"
  },
  "transitions": [
    {
      "from": "pending",
      "to": "plan-and-clarify",
      "actor": "orchestrator",
      "condition": null
    },
    {
      "from": "plan-and-clarify",
      "to": "clarification-asked",
      "actor": "owner",
      "condition": null
    },
    {
      "from": "clarification-asked",
      "to": "clarification-provided",
      "actor": "orchestrator",
      "condition": null
    },
    {
      "from": "clarification-provided",
      "to": "further-clarification",
      "actor": "owner",
      "condition": null
    },
    {
      "from": "clarification-provided",
      "to": "artifact-generated",
      "actor": "owner",
      "condition": null
    },
    {
      "from": "artifact-generated",
      "to": "contribution-needed",
      "actor": "orchestrator",
      "condition": "has-contributors"
    },
    {
      "from": "artifact-generated",
      "to": "contribution-not-needed",
      "actor": "orchestrator",
      "condition": "no-contributors"
    },
    {
      "from": "contribution-not-needed",
      "to": "final-review-needed",
      "actor": "orchestrator",
      "condition": "has-reviewer"
    },
    {
      "from": "contribution-not-needed",
      "to": "review-not-needed",
      "actor": "orchestrator",
      "condition": "no-reviewer"
    },
    {
      "from": "contribution-needed",
      "to": "contributed",
      "actor": "orchestrator",
      "condition": "all-contributors-done"
    },
    {
      "from": "contributed",
      "to": "refined",
      "actor": "owner",
      "condition": null
    },
    {
      "from": "refined",
      "to": "final-review-needed",
      "actor": "orchestrator",
      "condition": "has-reviewer"
    },
    {
      "from": "refined",
      "to": "review-not-needed",
      "actor": "orchestrator",
      "condition": "no-reviewer"
    },
    {
      "from": "review-not-needed",
      "to": "presented",
      "actor": "orchestrator",
      "condition": null
    },
    {
      "from": "final-review-needed",
      "to": "final-review-complete",
      "actor": "reviewer",
      "condition": null
    },
    {
      "from": "final-review-complete",
      "to": "final-review-needed",
      "actor": "orchestrator",
      "condition": "review-not-maxed"
    },
    {
      "from": "final-review-complete",
      "to": "presented",
      "actor": "orchestrator",
      "condition": "review-maxed-or-ready"
    },
    {
      "from": "presented",
      "to": "complete",
      "actor": "orchestrator",
      "condition": "decision-approve"
    },
    {
      "from": "presented",
      "to": "changes-requested",
      "actor": "orchestrator",
      "condition": "decision-reject"
    },
    {
      "from": "changes-requested",
      "to": "finalised",
      "actor": "owner",
      "condition": null
    },
    {
      "from": "finalised",
      "to": "presented",
      "actor": "orchestrator",
      "condition": null
    }
  ]
}
