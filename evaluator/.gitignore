# ── evaluator/.gitignore ──────────────────────────────────────────────
# The evaluator is a uv workspace (Python 3.13+) that drives the real
# kiro-cli / claude-cli terminals and scores their output. Everything below
# is generated, local, or machine-specific — never committed.

# Evaluation run artifacts (workspaces, aidlc-docs, reports, scored YAML).
# Each run is a timestamped, PID-stamped folder under runs/ — large and
# reproducible, so it stays out of git.
runs/

# Older output dirs + local scratch from ad-hoc coding sessions.
test_results/
reports/
ralph-coded/

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ── Virtual envs ──
.venv/
venv/
env/
ENV/

# ── Tooling caches ──
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
.tox/

# ── Local-only config (per-machine model/region overrides) ──
config.yaml

# ── Editors / OS ──
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs & secrets ──
*.log
.env

# ── Per-workspace harness distribution copied in by the adapters ──
.claude/
